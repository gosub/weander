<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Map fills top portion -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true" />

    <!-- Mission card at bottom -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/surface"
            android:padding="20dp">

            <!-- Distance info -->
            <TextView
                android:id="@+id/text_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="14dp" />

            <!-- Mission category label -->
            <TextView
                android:id="@+id/text_mission_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/accent"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Mission text (serif) -->
            <TextView
                android:id="@+id/text_mission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="19sp"
                android:fontFamily="serif"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.45"
                android:layout_marginBottom="22dp" />

            <!-- Re-roll buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btn_reroll_mission"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Re-roll mission"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:background="@drawable/bg_btn_secondary"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="8dp"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/btn_reroll_all"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Re-roll all"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:background="@drawable/bg_btn_secondary"
                    android:stateListAnimator="@null"
                    android:padding="10dp" />

            </LinearLayout>

            <!-- Complete button -->
            <Button
                android:id="@+id/btn_complete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_complete"
                android:textColor="@color/on_primary"
                android:textSize="15sp"
                android:background="@drawable/bg_btn_primary"
                android:stateListAnimator="@null"
                android:padding="14dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
