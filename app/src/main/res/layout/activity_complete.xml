<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Mission reminder header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_your_mission"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/text_mission_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/accent"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/text_mission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:fontFamily="serif"
            android:textColor="@color/text_primary"
            android:lineSpacingMultiplier="1.45"
            android:layout_marginBottom="24dp" />

        <!-- Photo preview (hidden until photo taken) -->
        <ImageView
            android:id="@+id/img_photo_preview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="12dp" />

        <!-- Camera / Gallery row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_take_photo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_take_photo"
                android:textColor="@color/primary"
                android:background="@drawable/bg_btn_secondary"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp"
                android:padding="12dp" />

            <Button
                android:id="@+id/btn_pick_photo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_pick_photo"
                android:textColor="@color/primary"
                android:background="@drawable/bg_btn_secondary"
                android:stateListAnimator="@null"
                android:padding="12dp" />

        </LinearLayout>

        <!-- Text entry -->
        <EditText
            android:id="@+id/edit_text_entry"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="@string/hint_text_entry"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:gravity="top|start"
            android:inputType="textMultiLine|textCapSentences"
            android:layout_marginBottom="16dp" />

        <!-- Audio recording -->
        <Button
            android:id="@+id/btn_record_audio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_record_audio"
            android:textColor="@color/primary"
            android:background="@drawable/bg_btn_secondary"
            android:stateListAnimator="@null"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/text_audio_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Save -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save"
            android:textColor="@color/on_primary"
            android:textSize="16sp"
            android:background="@drawable/bg_btn_primary"
            android:stateListAnimator="@null"
            android:padding="16dp" />

    </LinearLayout>
</ScrollView>
